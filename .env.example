# ── Runtime ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ─────────────────────────────────────────────
# Matches docker-compose.yml credentials
DATABASE_URL=postgresql://splitpay:splitpay@localhost:5432/splitpay?schema=public

# ── Telegram ─────────────────────────────────────────────
# From @BotFather
BOT_TOKEN=123456:ABC-your-bot-token-here
# The bot's @username, WITHOUT the leading @ (as shown by @BotFather).
BOT_USERNAME=YourBot
# How the bot receives updates:
#   polling  → no public URL needed (best for local dev)   [default]
#   webhook  → Telegram pushes to ${PUBLIC_URL}/webhook (needs a public HTTPS URL)
BOT_MODE=polling
# Public HTTPS base URL of THIS server (e.g. an ngrok/cloudflared tunnel).
# Required for webhook mode; under polling it defaults to http://localhost:PORT.
# Also the origin the Mini App button opens.
# PUBLIC_URL=https://your-tunnel.example.com
# Optional outbound proxy for the Telegram API (http/https), e.g. where Telegram
# is blocked. Routes bot traffic through it. SOCKS not supported.
# PROXY_URL=http://127.0.0.1:8080
# Dev-only: local /admin panel + X-Dev-User auth bypass. Defaults on when
# NODE_ENV!=production. Set to "false" to force off (or "true" to force on).
# DEV_AUTH=true

# ── TON settlement ───────────────────────────────────────
# Without TON_MNEMONIC the app uses an off-chain SIMULATION (full flow works
# locally, no wallet/testnet needed). Set the mnemonic to deploy a real escrow.
TON_NETWORK=testnet
# 24-word mnemonic of a FUNDED testnet wallet that deploys/pays out escrows.
# TON_MNEMONIC="word1 word2 ... word24"
# Optional toncenter API key (higher rate limit).
# TON_API_KEY=
